      <property name="styleSheet">
       <string notr="true">QSlider::groove:vertical {
    background: #313244;
    width: 6px;
    border-radius: 3px;
}

QSlider::sub-page:vertical {
    background: #313244;
    border-radius: 3px;
}

QSlider::add-page:vertical {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #89b4fa, stop:1 #b4befe);
    border-radius: 3px;
}

QSlider::handle:vertical {
    background: #f5e0dc;
    border: 2px solid #89b4fa;
    height: 16px;
    width: 16px;
    margin: 0 -5px;
    border-radius: 9px;
}

QSlider::handle:vertical:hover {
    background: #ffffff;
    border-color: #b4befe;
    transform: scale(1.2);
}</string>
